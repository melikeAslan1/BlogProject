{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=BlogDb;Username=postgres;Password=1234"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175",
      "http://localhost:5176",
      "http://localhost:5177",
      "http://localhost:5178",
      "http://localhost:5179"
    ]
  },
  "JwtSettings": {
    "Issuer": "BlogApi",
    "Audience": "BlogClient",
    "Key": "super-secret-dev-key-change-this",
    "ExpiryMinutes": 60
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200",
    "IndexName": "blog-posts",
    "Enabled": true,
    "ReindexOnStartup": true
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "FeaturedTtlSeconds": 60
  }
}